{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@gov/db": ["packages/db/src"],
      "@gov/shared": ["packages/shared/src"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "packages/admin",
    "packages/web",
    "packages/ui"
  ]
}
