# =============================================
#  Production environment template
#  - Copy to `.env` on the production VM (chmod 600)
#  - Never commit the real .env to git
# =============================================

# ----- Postgres (Container internal) -----
POSTGRES_USER=gov_app
POSTGRES_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD__
POSTGRES_DB=gov_platform

# ----- Redis (Container internal) -----
REDIS_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD__

# ----- MinIO (Object storage) -----
MINIO_ROOT_USER=gov_minio
MINIO_ROOT_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD__
S3_BUCKET=gov-media
S3_REGION=us-east-1

# ----- API -----
# 32+ random bytes. Generate with:  openssl rand -base64 48
JWT_SECRET=__REPLACE_WITH_OPENSSL_RAND__

# Comma-separated list of origins allowed to call the API.
# Example: https://admin.gov.taipei,https://gov.taipei,https://doit.gov.taipei
ALLOWED_ORIGINS=https://admin.gov.taipei

# ----- Admin (build-time NEXT_PUBLIC_*) -----
# This URL is BAKED into the admin bundle at docker build time.
# It must be the public URL clients use to reach the API (i.e. nginx host),
# not the internal compose hostname.
PUBLIC_API_URL=https://api.gov.taipei/api/v1
